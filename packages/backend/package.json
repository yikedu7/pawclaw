{
  "name": "@x-pet/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:smoke": "vitest run --reporter=verbose src/db/__tests__"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.0.0",
    "@x-pet/shared": "workspace:*",
    "drizzle-orm": "^0.40.0",
    "ethers": "^6.13.0",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "drizzle-kit": "^0.30.0",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.32.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  }
}
