DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
DATABASE_MIGRATION_URL=postgresql://user:password@host:5432/dbname
ANTHROPIC_API_KEY=sk-ant-...
ONCHAIN_OS_API_KEY=your-onchain-os-api-key
ONCHAIN_OS_API_URL=https://www.okx.com/priapi/v1/onchain-os
X_LAYER_RPC_URL=https://rpc.xlayer.tech
X402_FACILITATOR_URL=https://facilitator.x402.org
PORT=3000
# Supabase — used to verify JWTs via supabase.auth.getUser() on the server
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional
TELEGRAM_BOT_TOKEN=
# Hetzner VPS — remote Docker access via SSH tunneling (see docs/remote-docker-access.md)
HETZNER_HOST=
HETZNER_USER=deploy
HETZNER_SSH_KEY=
HETZNER_HOST_DATA_DIR=/data/pets
